---
// Student reviews — written testimonials in a swipeable carousel + a masonry
// wall of LinkedIn screenshots. Clean rebuild of the Webflow w-slider section
// (no webflow.js dependency): the carousel is a CSS scroll-snap track with
// arrow controls wired by a tiny scoped script.
const A = '/assets/664a5b263659c7265be280ad/';

const testimonials = [
  { name: 'Alex Pitcaithly', title: 'Dynamic People Leader', img: `${A}679c4c1c4e9c2e629f9dabd4_alex-pitcaithly.webp`, quote: "I just completed Bill Fanter's Options Masterclass; it was a great introduction to trading options and an overall enjoyable experience. Thank you, Bill, for sharing your knowledge, looking forward to your continued mentoring and friendship. If you want to learn about the options market from someone who is a successful trader and passionate to share his skills, then I highly recommend Bill's Masterclass." },
  { name: 'Dan Funderburk, MBA', title: 'Executive Recruiting at H-E-B', img: `${A}679c4f04407a54b6277c94f3_dan-funderburk.webp`, quote: "I can't say enough about Bill Fanter! This masterclass was a true eye-opener. As a former financial advisor in a previous life, I learned things in Bill's class that I never had before. I had limited, cursory knowledge of the markets, charting, and supply & demand, but now I have the skills, albeit very green, to provide a lifetime of return. And the education doesn't stop with the class. There is a community of like-minded traders, all ready and willing to help and lend a hand. I'm super thankful for this opportunity and look forward to the journey ahead." },
  { name: 'Danielle G', title: 'Sr. Epic Application Specialist', img: `${A}679c4ad9a63b20955c05a779_danielle-g.webp`, quote: "Do not wait to get involved! Bill's master class is highly informative and so well presented. He is an expert with knowledge beyond what most traders have and is incredibly responsive with questions. I cannot say enough about this class nor the incredible trading community Bill has created. You will see returns in multiple forms, not just monetary. With the economy frequently in question and the many uncertainties in life, securing one's financial well being is a strong priority. Why wait? LFG!!" },
  { name: 'John Gordy', title: 'Chief Financial Officer at DroneUp', img: `${A}678e77c8a0abd734e3415731_jogn-gordy.avif`, quote: "Thank you Bill for your mentorship! I'm a huge advocate of your patient & disciplined approach to trading. Learning the correct way to identify & trade liquidity while managing risk is a valuable skill that can be lifechanging when executed properly!" },
  { name: 'Riley H', title: 'Sales Specialist at AB Laboratories Inc.', img: `${A}678e7871274732ce809d928f_riley-h.avif`, quote: "It was an absolute joy learning from Bill. The brightest people can take complex ideas and explain them with simplicity. Bill certainly exemplifies this. I'm very much looking forward to continuing to grow my knowledge alongside the great community Bill has created. Thank you for your time Bill, it's much appreciated!" },
  { name: 'Stijn Ceelen', title: 'Seasoned C-level leader in Banking & Wealth(Tech)', img: `${A}678e78e0ad106cbe59c5e816_stijn-ceelen.avif`, quote: "Just wrapped up the masterclass in options trading with Bill Fanter, and I have to say, I absolutely loved it! This old fox (me) picked up some new tricks, proving once again that life always has more to teach you. A big thank you to Bill Fanter for being not just a great teacher, but also a fantastic person and mentor. Your insights and approach make all the difference! Now, time to put your lessons into action 🚀" },
  { name: 'Rob Stalkie', title: 'Account Manager', img: `${A}679c51ea7d9046f26ec04264_rob-stalkie.webp`, quote: "Bill's Masterclass was incredibly informative and fun. He weaves in and out of topics from trading psychology to charting and makes every lesson accessible to complete beginners. Well worth it!" },
  { name: 'David Lawson', title: 'Founder Icegreen - Beautiful Bags For Brands', img: `${A}678e7a667540897023632d1b_david-lawson.avif`, quote: "I just finished taking Bill Fanter's Master Class. It has been an amazing experience. Bill teaches a complex subject and presents it in a way that is easy to process and understand. I feel very grateful to come across Bill and this opportunity. He has big heart and cares about his students. I would highly recommend this course if you have an interest in trading options. Thank you very much Bill for what you have put into this, I look forward to learning and working with in the future." },
];

// LinkedIn screenshot wall — full-size sources, masonry across columns.
const screenshots = [
  '68762145f84c52b1d73b6639_Screenshot%202025-07-11%20at%204.35.49%E2%80%AFPM.webp',
  '687621ada403613c0a3bf9af_Screenshot%202025-07-11%20at%204.36.25%E2%80%AFPM.webp',
  '687621cda307f7320689063b_Screenshot%202025-07-11%20at%204.36.38%E2%80%AFPM.webp',
  '687621e6a05e43a792e67ecb_Screenshot%202025-07-11%20at%204.36.52%E2%80%AFPM.webp',
  '6876224cb841f03797602362_Screenshot%202025-07-11%20at%204.37.58%E2%80%AFPM.webp',
  '687622afa403613c0a3d2313_Screenshot%202025-07-11%20at%204.38.40%E2%80%AFPM.webp',
  '687622c7b4b62d3a9e0a9cbb_Screenshot%202025-07-11%20at%204.38.54%E2%80%AFPM.webp',
  '687622e9b4b62d3a9e0ac571_Screenshot%202025-07-11%20at%204.39.05%E2%80%AFPM.webp',
  '68762304b841f0379760ecc0_Screenshot%202025-07-11%20at%204.39.24%E2%80%AFPM.webp',
  '68762321751e88dc018a9bbb_Screenshot%202025-07-11%20at%204.39.37%E2%80%AFPM.webp',
