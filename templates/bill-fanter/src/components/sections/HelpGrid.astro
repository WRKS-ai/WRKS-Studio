---
// Value-proposition icon grid. Content sourcing:
//   1. `content` prop from /preview/[jobId] wins.
//   2. Fallback = content.sample.helpGrid (canonical Bill-Fanter).
import { content as sampleContent } from '../../data/content.sample';
import type { HelpGridContent } from '../../data/content.schema';
interface Props {
  content?: HelpGridContent;
}
const { content: propContent } = Astro.props;
const help = propContent ?? sampleContent.helpGrid;
---
<section class="bf-section">
  <div class="bf-container">
    <div class="bf-section-header is-center">
      <h2 class="bf-h2">{help.heading}</h2>
    </div>
    <div class="bf-help-grid bf-help-grid--three">
      {help.cards.map((c) => (
        <div class="bf-help-card">
          <div class="bf-help-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={c.iconPaths} />
          </div>
          <div class="bf-help-card__title">{c.title}</div>
          <p class="bf-body">{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Three cards (was four nav cards) — constrained, centered. */
  .bf-help-grid--three {
    grid-template-columns: repeat(3, 1fr);
    max-width: 1040px;
    margin-left: auto;
    margin-right: auto;
  }
  @media (max-width: 860px) { .bf-help-grid--three { grid-template-columns: 1fr; max-width: 480px; } }
</style>
