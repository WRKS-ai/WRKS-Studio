---
// Trading community — Discord screenshot beside an animated benefits list.
// WRKS template: defaults read from content.community. Pages that reuse
// this block can still override via Astro.props (e.g. masterclass page
// uses a different CTA label).
import { content } from '../../data/content.sample';
const community = content.community;
const benefits = community.benefits;
const ssSrc = community.screenshot.src;
const ssSrcset = `${ssSrc.replace(/\.webp$/, '-720.webp')} 1x, ${ssSrc} 2x`;
const {
  ctaHref = community.cta.href,
  ctaLabel = community.cta.label,
  heading = community.heading,
  lead = community.lead,
} = Astro.props;
---
<section class="bf-section" id="community-2026">
  <div class="bf-container">
    <div class="bf-section-header is-center">
      <h2 class="bf-h2">{heading}</h2>
      <p class="bf-lead">{lead}</p>
    </div>
    <div class="bf-community-grid">
      <div class="bf-community__media">
        <img src={ssSrc} srcset={ssSrcset} alt={community.screenshot.alt} />
      </div>
      <div class="bf-community__benefits">
        <div data-benefits-list style="display:contents">
          {benefits.map((b) => (
            <div class="bf-benefit">
              <div class="bf-benefit__num">{b.num}</div>
              <div>
                <div class="bf-benefit__title">{b.title}</div>
                <p class="bf-body">{b.body}</p>
              </div>
            </div>
          ))}
        </div>
        <a class="bf-btn bf-btn--primary" href={ctaHref} style="margin-top:8px;align-self:flex-start">
          {ctaLabel}
          <svg class="bf-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  #community-2026.bf-section {
    background: #ffffff;
  }
  /* Map the AnimatedList fade (driven via --bf-reveal) onto the benefit rows.
     Defaults to 1 (fully visible) when the island hasn't set the variable. */
  .bf-community__benefits .bf-benefit {
    opacity: var(--bf-reveal, 1);
  }
  /* Discord phone mockup: slightly smaller + raised toward the top of the row. */
  #community-2026 .bf-community__media {
    align-self: start;
  }
  #community-2026 .bf-community__media img {
    width: 88%;
    margin-inline: auto;
  }
</style>
