---
// Homepage hero — dark stage with a React Bits DotGrid background
// (mounted by BaseLayout's global [data-dotgrid] script), headline +
// dual CTA + trust row on the left rail, right-anchored portrait that
// lines up with the bento split below.
//
// WRKS template refactor (2026-06-30): all editable copy now reads from
// `content.hero` slots (see ../../data/content.schema.ts). Layout,
// classnames, and visual behavior are unchanged — only string literals
// moved out of the markup.
import { content } from '../../data/content.sample';
const hero = content.hero;
const star = '<path d="M12 2l3 7 7 .8-5 5 1.5 7-6.5-3.5L5 22l1.5-7-5-5L8.5 9z"/>';
---
<section class="bf-hero2026">
  <div
    class="bf-hero2026__dots"
    data-dotgrid
    data-dot-size="2"
    data-gap="10"
    data-base-color="#454545"
    data-active-color="#75B5FF"
    data-proximity="140"
    data-return-duration="0.6"
  ></div>
  <div class="bf-hero2026__scrim" aria-hidden="true"></div>

  <div class="bf-container bf-hero2026__inner">
    <h1 class="bf-hero2026__h1">{hero.headline}</h1>
    <p class="bf-hero2026__sub">{hero.subhead}</p>
    <div class="bf-hero2026__cta">
      <a href={hero.primaryCta.href} class="bf-btn bf-btn--primary is-on-dark">{hero.primaryCta.label}</a>
      <a href={hero.secondaryCta.href} class="bf-btn bf-btn--secondary is-on-dark">{hero.secondaryCta.label}</a>
    </div>
    <div class="bf-hero2026__trust">
      <span class="bf-hero2026__trust-label">{hero.trust.label}</span>
      <span class="bf-hero2026__trust-stars">
        {Array.from({ length: hero.trust.rating }).map(() => (
          <svg class="bf-star" viewBox="0 0 24 24" set:html={star} />
        ))}
      </span>
      <span class="bf-hero2026__trust-count">{hero.trust.count}</span>
    </div>
  </div>

  <div class="bf-hero2026__image">
    <img
      src={hero.portrait.src}
      fetchpriority="high"
      alt={hero.portrait.alt}
    />
    {/* Introduces the man in the photo: name + one credential. */}
    <div class="bf-hero2026__namecard">
      <span class="bf-hero2026__namecard-name">{hero.namecard.name}</span>
      <span class="bf-hero2026__namecard-role">{hero.namecard.role}</span>
    </div>
  </div>
</section>

<style>
  .bf-hero2026 {
    position: relative;
    overflow: hidden;
    background: #0a0a0a;
    color: #fff;
    isolation: isolate;
  }
  .bf-hero2026__dots {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.66;
    pointer-events: auto;
  }
  /* Scrim sits BELOW the dots (z-index 0) and is lighter, so the dots read
     brighter instead of being washed out by an overlay on top of them. */
  .bf-hero2026__scrim {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: rgba(10, 10, 10, 0.5);
  }
  /* Content rail — sits above the dots/scrim. Vertical padding (not min-height)
     drives the hero height so the right-anchored image fills edge-to-edge. */
  /* The CardNav (72px) overlays the top of the hero, so the top padding must be
     larger than the bottom by ~the nav height for the visual top/bottom gaps to
     read even. 184 top → 112 visual below the nav, matched by 112 bottom. */
  .bf-hero2026__inner {
    position: relative;
    z-index: 3;
    padding-top: 272px;
    padding-bottom: 200px;
  }
  .bf-hero2026__h1 {
    max-width: 820px;
    margin: 0;
    font-size: 5rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.04;
    color: #fff;
  }
  .bf-hero2026__sub {
    max-width: 560px;
    margin: 24px 0 0;
    font-size: 18px;
    line-height: 1.55;
    /* Pure white on the dot-grid hero. */
    color: #fff;
  }
  .bf-hero2026__cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 36px;
  }
  .bf-hero2026 .bf-btn {
    display: inline-flex;
    width: auto;
    border-radius: 999px;
    padding: 14px 26px;
    white-space: nowrap;
  }
  .bf-hero2026__trust {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px 10px;
    margin-top: 28px;
    /* Nudge slightly right to correct the optical-alignment illusion against the
       pill CTAs above (their text sits inset from the pill edge). */
    margin-left: 6px;
    font-size: 14px;
    font-weight: 500;
  }
  /* Keep each text unit on one line so the row reads naturally (one line, or
     wrapping as whole units) instead of squeezing into stacked columns. */
  .bf-hero2026__trust-label,
  .bf-hero2026__trust-count { white-space: nowrap; }
  .bf-hero2026__trust-stars {
    display: inline-flex;
    gap: 2px;
  }
  .bf-hero2026__trust-stars .bf-star {
    width: 16px;
    height: 16px;
    fill: #ffc14d;
  }
  .bf-hero2026__trust-count {
    color: #fff;
    font-weight: 400;
  }
  /* Right-anchored portrait. Left edge at 57% lines it up with the bento split
     in the watchlist section below; crop anchored to the TOP so the subject's
     head stays in frame and overflow trims from the bottom. */
  .bf-hero2026__image {
    position: absolute;
    top: 0;
    bottom: 0;
    /* Left edge lands on the watchlist grid line (body-text / blue-tile left
       edge), matching the split nav edge so they share one vertical line. */
    left: min(65vw, calc((100vw - 1440px) / 2 + 937px));
    right: 0;
    z-index: 2;
  }
  .bf-hero2026__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  /* "This is Bill" intro card — static frosted pill, lower-left of the portrait. */
  .bf-hero2026__namecard {
    position: absolute;
    left: 24px;
    bottom: 24px;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 12px 18px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.92);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }
  .bf-hero2026__namecard-name { font-size: 16px; font-weight: 700; line-height: 1.1; color: #0a0a0a; }
  .bf-hero2026__namecard-role { font-size: 13px; font-weight: 500; color: rgba(10, 10, 10, 0.6); }

  @media (max-width: 991px) {
    .bf-hero2026__inner { padding-top: 136px; padding-bottom: 64px; }
    .bf-hero2026__h1 { font-size: clamp(40px, 8vw, 64px); }
  }
  @media (max-width: 767px) {
    .bf-hero2026 { display: flex; flex-direction: column; }
    /* Match the other dot-grid heroes on mobile: ~52px of breathing room below
       the nav (72px nav + 52 = 124 top) and an even 52px bottom. */
    .bf-hero2026__inner { padding-top: 124px; padding-bottom: 52px; }
    .bf-hero2026__h1 { font-size: clamp(34px, 9vw, 48px); max-width: none; }
    /* Stack the portrait below the copy instead of overlapping it. */
    .bf-hero2026__image {
      position: relative;
      left: 0;
      height: 340px;
    }
  }
</style>
