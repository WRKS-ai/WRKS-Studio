---
// "Welcome to Bill Fanter" split — media LEFT, copy RIGHT. WRKS template:
// accepts a `content` prop OR falls back to content.sample.heroSplit.
// Also supports the legacy per-field props (eyebrow, heading, etc.)
// which existing pages pass for one-off overrides.
import { content as sampleContent } from '../../data/content.sample';
import type { HeroSplitContent } from '../../data/content.schema';
interface Props {
  content?: HeroSplitContent;
  eyebrow?: string | null;
  heading?: string;
  lead?: string;
  ctaLabel?: string;
  ctaHref?: string;
}
const { content: propContent, ...legacyProps } = Astro.props;
const hs = propContent ?? sampleContent.heroSplit;
const star = '<path d="M12 2l3 7 7 .8-5 5 1.5 7-6.5-3.5L5 22l1.5-7-5-5L8.5 9z"/>';
const dsrc = (p) => `${p.replace(/\.webp$/, '-720.webp')} 1x, ${p} 2x`;
const photoSrc = hs.photo.src;
const {
  eyebrow = hs.eyebrow,
  heading = hs.heading,
  lead = hs.lead,
  ctaLabel = hs.cta.label,
  ctaHref = hs.cta.href,
} = legacyProps;
---
<section class="bf-section bf-hero-split-wrap">
  <div class="bf-container">
    <div class="bf-hero-split">
      <div class="bf-hero-split__grid">
        <div class="bf-hero-split__copy">
          {eyebrow && <div class="bf-hero__eyebrow"><span class="bf-eyebrow">{eyebrow}</span></div>}
          <h2 class="bf-h1 bf-hero__h1">{heading}</h2>
          <p class="bf-lead bf-hero__lead">{lead}</p>
          <div class="bf-hero__cta">
            <a class="bf-btn bf-btn--primary" href={ctaHref}>{ctaLabel}</a>
          </div>
          <div class="bf-hero__trust">
            <span class="bf-hero__trust-source">{hs.trust.label}</span>
            <span class="bf-hero__trust-stars">
              {Array.from({ length: hs.trust.rating }).map(() => (
                <svg class="bf-star" viewBox="0 0 24 24" set:html={star} />
              ))}
            </span>
            <span>{hs.trust.count}</span>
          </div>
        </div>

        <div class="bf-hero-split__bento">
          <div class="bf-hero-split__video">
            <button type="button" class="bf-vreel" data-bf-vimeo={hs.videoVimeoId} aria-label="Watch Bill's intro short">
              <span class="bf-vreel__frame">
                <iframe class="bf-vreel__video" data-bf-lazysrc={`https://player.vimeo.com/video/${hs.videoVimeoId}?background=1&autoplay=1&muted=1&loop=1&controls=0&playsinline=1&dnt=1`} allow="autoplay; fullscreen" loading="lazy" title="Intro video"></iframe>
                <span class="bf-vreel__overlay"></span>
                <span class="bf-vreel__play" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><polygon points="8 5 19 12 8 19 8 5" fill="currentColor"/></svg>
                </span>
              </span>
            </button>
          </div>
          <div class="bf-hero-split__tile bf-hero-split__tile--quote-on-gradient">
            <div class="bf-grainient-mount" data-grainient="split-hero" data-color1="#FF8308" data-color2="#EF4444" data-color3="#6B3BD5"></div>
            <div class="bf-hero-split__tile-content">
              <p class="bf-hero-split__tile-quote">&ldquo;{hs.quote.text}&rdquo;</p>
              <div class="bf-hero-split__tile-footer">
                <div class="bf-hero-split__tile-author">
                  <div class="bf-hero-split__tile-author-name">{hs.quote.name}</div>
                  <div class="bf-hero-split__tile-author-title">{hs.quote.title}</div>
                </div>
                <a class="bf-hero-split__tile-link" href={hs.quoteLink.href}>{hs.quoteLink.label} <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
              </div>
            </div>
          </div>
          <div class="bf-hero-split__tile bf-hero-split__tile--photo">
            <img src={photoSrc} srcset={dsrc(photoSrc)} alt={hs.photo.alt} />
          </div>
        </div>
      </div>
    </div>
    {/* Optional extra content rendered inside this section's container, below the
        media+copy grid (e.g. the masterclass page's feature tiles). */}
    <slot />
  </div>
</section>

<style>
  /* This is wrapped in <section class="bf-section"> (80px padding), but
     .bf-hero-split also carries its own section padding in the design system —
     zero it here so the top/bottom spacing isn't doubled (the 160px ghost gap). */
  .bf-hero-split { padding-top: 0 !important; padding-bottom: 0 !important; }
  /* The blue spotlight above already contributes a full section pad of white
     below its card; our own top pad stacked on top of it doubled the gap (160 vs
     80 below). Drop the top pad so the visual top gap matches the bottom. */
  .bf-hero-split-wrap { padding-top: 0; }
  /* Vertically center the copy against the (taller) bento column. */
  .bf-hero-split__grid { align-items: center; }
  /* Swap column order: media LEFT, copy RIGHT. */
  .bf-hero-split__bento { order: 1; }
  .bf-hero-split__copy {
    order: 2;
    /* The design's separation was built for copy-on-left; after the swap the
       copy hugs the bento, so add left padding to even out the column gap. */
    padding-left: 48px;
  }
  /* Match the headline to the watchlist "Get your free weekly…" size. */
  .bf-hero-split__copy .bf-h1 {
    font-size: clamp(24px, 2.6vw, 36px);
  }
  /* Photo tile fills its grid cell so the right column's quote + photo stack
     stays exactly as tall as the video pillar — no overflow past the video
     frame. The img is absolutely positioned so its (portrait) natural height
     can't dictate the row; it just covers the cell the grid gives it. */
  .bf-hero-split__tile--photo {
    position: relative;
    overflow: hidden;
    min-height: 0;
  }
  .bf-hero-split__tile--photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 800px) {
    .bf-hero-split__copy { padding-left: 0; }
  }

  /* Tablet/phone: the design-system 2-col bento puts a narrow centered video
     beside a wider quote card (reads lopsided). Stack it into one centered column
     — video, quote, then photo — from 980px down. Scoped to this instance so the
     shared bento layout elsewhere is untouched. */
  @media (max-width: 980px) {
    /* Stacked: copy + CTA read first, then the bento (video / quote / photo). */
    .bf-hero-split__copy { order: 1; }
    .bf-hero-split__bento { order: 2; }
    .bf-hero-split__bento {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      max-width: 440px;
      margin: 0 auto;
    }
    .bf-hero-split__video {
      grid-row: auto;
      /* Explicit width: the tile's only child (the iframe) is absolutely
         positioned, so without a definite width `margin: 0 auto` collapses the
         grid item to 0 (and the aspect-ratio then yields 0 height → video
         vanished on mobile). */
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }
    /* The photo tile's <img> is absolutely positioned, so in a single-column
       auto-row track it has no intrinsic height — give it a ratio to stay visible. */
    .bf-hero-split__tile--photo { aspect-ratio: 16 / 10; }
  }
  /* Phones: let the quote + photo tiles run the full container width (matching the
     other bento cards site-wide); only the vertical video reel stays capped. */
  @media (max-width: 560px) {
    /* Phones: the bento + the video reel both span the full container width. */
    .bf-hero-split__bento { max-width: none; }
    .bf-hero-split__video { max-width: none; }
  }
</style>
