---
<!-- ===== Cinematic dark zone: dot-grid hero + the two video rows ===== -->
<div class="bf-cinema">
  <!-- Dot grid spans the WHOLE cinema zone (hero + both video rows) so the video
       embeds sit on the same grid-dot backdrop, not a separate flat bg. -->
  <div class="bf-cinema__dots" data-dotgrid data-dot-size="2" data-gap="10" data-base-color="#454545" data-active-color="#75B5FF" data-proximity="140" data-return-duration="0.6"></div>
  <section class="bf-rev-hero bf-section bf-hero">
    <div class="bf-container">
      <div class="bf-hero__inner">
        <h1 class="bf-h1 bf-hero__h1">Real options trading reviews from Bill Fanter's students</h1>
      </div>
    </div>
  </section>

<!-- Roundtable video showcase (live-site addition, rebuilt clean) -->
<section class="bf-video-showcase bf-section">
  <div class="bf-container">
    <div class="bf-section-header is-center">
      <div class="bf-vs-eyebrow">Roundtable discussions</div>
      <h2 class="bf-h2">Inside Bill's best trades</h2>
      <p class="bf-vs-subhead">Three roundtable conversations breaking down the strategies, decisions, and instincts behind some of Bill Fanter's most talked-about trades.</p>
    </div>
    <div class="bf-vs-grid">
      <article class="bf-vs-card featured" data-vid="Te0c1iem3vI">
        <button class="bf-vs-thumb" type="button" data-bf-youtube="Te0c1iem3vI" data-bf-wide aria-label="Play the most recent roundtable about Bill Fanter">
          <img src="https://img.youtube.com/vi/Te0c1iem3vI/maxresdefault.jpg" loading="lazy" alt="" />
          <span class="bf-vs-play" aria-hidden="true"><svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 5v14l11-7z" fill="currentColor"/></svg></span>
        </button>
        <div class="bf-vs-meta"><span class="bf-vs-tag">Most Recent</span></div>
      </article>
      <article class="bf-vs-card side" data-vid="xZ5RiPLQl8E">
        <button class="bf-vs-thumb" type="button" data-bf-youtube="xZ5RiPLQl8E" data-bf-wide aria-label="Play the earlier roundtable about Bill Fanter">
          <img src="https://img.youtube.com/vi/xZ5RiPLQl8E/maxresdefault.jpg" loading="lazy" alt="" />
          <span class="bf-vs-play" aria-hidden="true"><svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 5v14l11-7z" fill="currentColor"/></svg></span>
        </button>
        <div class="bf-vs-meta"><span class="bf-vs-tag">Earlier</span></div>
      </article>
      <article class="bf-vs-card side" data-vid="5SgfaRbprQs">
        <button class="bf-vs-thumb" type="button" data-bf-youtube="5SgfaRbprQs" data-bf-wide aria-label="Play the first roundtable about Bill Fanter">
          <img src="https://img.youtube.com/vi/5SgfaRbprQs/maxresdefault.jpg" loading="lazy" alt="" />
          <span class="bf-vs-play" aria-hidden="true"><svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 5v14l11-7z" fill="currentColor"/></svg></span>
        </button>
        <div class="bf-vs-meta"><span class="bf-vs-tag">The First</span></div>
      </article>
    </div>
  </div>
</section>

<VideoTestimonials />
</div>
<!-- /cinema -->

<section class="bf-section">
  <div class="bf-container">
    <div class="bf-section-header is-center">
      <h2 class="bf-h2">Students testimonials</h2>
    </div>
    <div class="bf-screenshots">
      {shots.map((src, i) => (
        <figure class="bf-screenshots__item">
          <img src={src} alt={`Student testimonial screenshot ${i + 1}`} loading="lazy" />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  /* ===== Cinematic dark zone: dot-grid hero + the two video rows =====
     One uniform dark backdrop (no radial ellipse glows) so the hero + both video
     rows read as a single continuous section. */
  .bf-cinema { position: relative; background: #07080c; color: #fff; }
  .bf-cinema > * { position: relative; z-index: 1; }
  /* Dot grid behind the ENTIRE cinema zone (hero + both video rows). Sits below
     the content (z-index 0). Content sections are transparent so the dots show
     through behind the video embeds too. */
  .bf-cinema > .bf-cinema__dots { position: absolute; inset: 0; z-index: 0; opacity: 0.55; pointer-events: none; }

  /* Hero shares the standard company-page .bf-hero spacing + .bf-h1 size (matches
     /contact). Bottom pad zeroed so the gap into the first video row is a single
     section pad. No glow vignette — it dimmed the dots + H1 unevenly vs the rows
     below, so the dot grid + headline color now read uniform across the zone. */
  /* Identical padding across every subpage dot-grid hero: even 150px top+bottom. */
  .bf-rev-hero { position: relative; padding-top: 150px; padding-bottom: 150px; }
  /* Mobile: even 52px top + bottom, consistent across every dot-grid hero. */
  @media (max-width: 767px) {
    .bf-rev-hero { padding-top: 52px; padding-bottom: 52px; }
  }
  .bf-cinema :global(.bf-h1) { color: #fff; }

  /* Roundtable showcase — now on the dark cinema backdrop. Bottom pad zeroed so
     the gap into the "Hear it straight from students" row is a single section
     pad, not a doubled one. */
  /* Top pad zeroed so the hero's 150px bottom is the single gap into the first
     video row (not a doubled 250px); bottom zeroed so the gap into "Hear it
     straight from students" is a single section pad. */
  .bf-video-showcase { background: transparent; padding-top: 0; padding-bottom: 0; }
  .bf-cinema .bf-h2 { color: #fff; }
  /* Left-aligned row titles (Netflix-style) for both video rows. */
  .bf-cinema .bf-section-header,
  .bf-cinema :global(.bf-vidtest .bf-section-header) { text-align: left; align-items: flex-start; max-width: none; }
  .bf-vs-eyebrow { display: inline-block; font-size: .75rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: #75B5FF; }
  .bf-vs-subhead { color: #fff; max-width: 600px; margin-left: 0; margin-right: 0; }
  .bf-cinema :global(.bf-vidtest .bf-lead) { margin-left: 0; margin-right: 0; max-width: 600px; }
  .bf-vs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; align-items: start; margin-top: 44px; }

  /* Netflix-style cards: a cinematic thumbnail that scales + glows on hover. */
  .bf-vs-card { position: relative; background: transparent; border: 0; border-radius: 12px; overflow: visible; display: flex; flex-direction: column; transition: transform .35s cubic-bezier(.2,.7,.2,1); }
  .bf-vs-card:hover { transform: translateY(-6px) scale(1.05); z-index: 5; }
  .bf-vs-thumb { position: relative; display: block; width: 100%; aspect-ratio: 16 / 9; border: 0; padding: 0; margin: 0; background: #000; cursor: pointer; overflow: hidden; border-radius: 12px; font: inherit; color: inherit; box-shadow: 0 18px 44px -16px rgba(0,0,0,0.75); transition: box-shadow .35s; }
  .bf-vs-card:hover .bf-vs-thumb { box-shadow: 0 32px 72px -20px rgba(0,0,0,0.9), 0 0 0 2px rgba(117,181,255,0.55); }
  .bf-vs-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .6s ease; }
  .bf-vs-thumb::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0) 45%, rgba(0,0,0,.55) 100%); pointer-events: none; }
  .bf-vs-card:hover .bf-vs-thumb img { transform: scale(1.06); }
  .bf-vs-play { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 66px; height: 66px; border-radius: 50%; background: rgba(255,255,255,0.92); color: #0a0a0a; display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 24px rgba(0,0,0,.4); transition: transform .3s cubic-bezier(.34,1.56,.64,1), background .2s; z-index: 2; }
  .bf-vs-play svg { width: 26px; height: 26px; margin-left: 3px; fill: currentColor; }
  .bf-vs-thumb:hover .bf-vs-play { transform: translate(-50%,-50%) scale(1.12); background: #fff; }
  /* Tag chip overlaid on the thumbnail (replaces the old white meta bar). */
  .bf-vs-meta { position: absolute; left: 12px; bottom: 12px; padding: 0; margin: 0; background: transparent; z-index: 3; }
  .bf-vs-tag { display: inline-block; font-size: .68rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: #fff; background: rgba(255,255,255,0.14); -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.32); padding: .4rem .8rem; border-radius: 999px; }
  .bf-vs-card.featured .bf-vs-tag { background: #4d65ff; border-color: #4d65ff; }
  .bf-vs-thumb.is-playing { cursor: default; }
  .bf-vs-thumb.is-playing img, .bf-vs-thumb.is-playing::after, .bf-vs-thumb.is-playing .bf-vs-play { display: none; }
  .bf-vs-card:has(.is-playing), .bf-vs-card:has(.is-playing):hover { transform: none; }
  .bf-vs-iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; border-radius: 12px; }

  /* VideoTestimonials ("Hear it straight from students") inside the cinema zone */
  .bf-cinema :global(.bf-vidtest) { background: transparent; }
  .bf-cinema :global(.bf-vidtest .bf-h2) { color: #fff; }
  .bf-cinema :global(.bf-vidtest .bf-lead) { color: #fff; }
  /* Hover stays INSIDE the card (image zoom) instead of scaling/lifting the whole
     card — the slider track's overflow was cropping a scaled card at the top and
     at the left edge (the leftmost card). */
  .bf-cinema :global(.bf-vidtest-thumb img) { transition: transform .5s ease; }
  .bf-cinema :global(.bf-vidtest-thumb:hover img) { transform: scale(1.06); }

  /* Equal gap between the section copy and the slider for BOTH video rows
     (roundtable grid + testimonials slider), so the two sections read the same. */
  .bf-cinema .bf-vs-grid,
