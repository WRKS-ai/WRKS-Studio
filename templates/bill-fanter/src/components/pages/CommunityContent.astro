// "Inside the community" — daily-activity modules, re-homed into a homepage
// card grid (like HelpGrid).
const insideModules = [
  { num: '01', title: 'Live trade alerts & market analysis', desc: 'Bill and the analysts drop real-time signals and watchlists.' },
  { num: '02', title: 'Trade talk & strategy discussions', desc: 'Active channels for quick scalp ideas, swing setups, and chart reviews.' },
  { num: '03', title: 'Video tutorials & educational resources', desc: 'Step-by-step guides, recorded sessions, and how-to videos anytime you need them.' },
  { num: '04', title: 'Member trade reviews & feedback', desc: 'Community members post wins, losses, and learnings, keeping it real and transparent.' },
  { num: '05', title: 'Market news & earnings alerts', desc: 'Stay up-to-date with the latest information so you never miss critical events or shifts.' },
];

// Production FAQ — verbatim Q&A.
const faqs = [
  { q: 'Do I need prior trading experience?', a: 'No. New traders join to learn the basics, and experienced traders join to sharpen entries and risk. Bill teaches both in plain language.' },
  { q: 'How much time do I need to commit?', a: 'As little as one focused hour around the open. The alerts, notes, and recordings are there whenever you can check in.' },
  { q: 'What if I lose money?', a: 'Trading options carries real risk, and losses are part of it. The community focuses on defined risk and position sizing so you control your downside on every trade. Nothing here is a guarantee of profit.' },
  { q: 'Can I trade while working a full-time job?', a: 'Yes. Many members trade the opening hour, then log off and go about their day. The alerts and watchlist fit a quick morning routine.' },
  { q: 'Is the community good for beginners?', a: 'Yes. Beginners get a clear starting point, step-by-step lessons, and a community to ask questions as they learn.' },
