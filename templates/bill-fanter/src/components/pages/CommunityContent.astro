---
// /community page body — rebuilt as a CLONE of the homepage design. Every
// section now uses a canonical homepage pattern (Hero, Reviews video+wall,
// .bf-darkcta grainient CTA, Community image + numbered benefits, AboutBill
// 50/50, bf-* card grids), with this page's copy re-homed in. The shared
// CardNav island + Footer come from community/index.astro; grainient fills are
// mounted by the Islands script.
//
// CONTENT is preserved verbatim from the prior page (which was itself
// reconciled against production /community): every headline, paragraph, pillar,
// review, FAQ, image, price and Whop checkout URL is intact — only the section
// wrappers/styles changed to match the homepage.
//
// LOAD-BEARING / unchanged: the HERO, the CommunityPricing component, the
// "How it works" 3-step-with-images block, and all Whop checkout URLs.
import CommunityPricing from '../sections/CommunityPricing.astro';
import YoutubeCta from '../sections/YoutubeCta.astro';
import Reviews from '../sections/Reviews.astro';
import Signature from '../Signature.astro';

const ASSET = '/assets/664a5b263659c7265be280ad';

// "A trading community that never sleeps" pillars — verbatim copy + icons from
// the production page, re-homed into the homepage's clean white card-grid
// language (was an off-brand full-bleed orange CTA, which doesn't exist on the
// homepage). Bodies carry production punctuation as-is (set:html).
