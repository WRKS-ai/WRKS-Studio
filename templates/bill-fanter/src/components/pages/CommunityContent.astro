  .bf-pmodal__opt { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 16px 18px; border: 1px solid rgba(10, 10, 10, 0.12); border-radius: 12px; text-decoration: none; color: #0a0a0a; transition: border-color 150ms, transform 150ms; }
  .bf-pmodal__opt + .bf-pmodal__opt { margin-top: 12px; }
  .bf-pmodal__opt:hover { border-color: #0a0a0a; transform: translateY(-1px); }
