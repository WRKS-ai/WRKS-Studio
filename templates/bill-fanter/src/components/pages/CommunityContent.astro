---
{/* =========================================================================
    HERO — kept exactly as-is.
    ========================================================================= */}
<section class="bf-section bf-hero bf-comm-hero">
  <div class="bf-comm-hero__dots" data-dotgrid data-dot-size="2" data-gap="10" data-base-color="#454545" data-active-color="#75B5FF" data-proximity="140" data-return-duration="0.6"></div>
  <div class="bf-comm-hero__scrim" aria-hidden="true"></div>
  <div class="bf-container">
    <div class="bf-hero__inner">
      <div class="bf-hero__eyebrow"><span class="bf-eyebrow">Trades you can bank on, every day!</span></div>
      <h1 class="bf-h1 bf-hero__h1">Trade options every day with Bill and a community of 1,000+ serious traders</h1>
      <p class="bf-lead bf-hero__lead">Get live trade alerts, daily market analysis, and mentorship from Bill Fanter, a former banker with 35+ years in the markets. Trade alongside 1,000+ members who share setups, manage risk, and sharpen their options trading every day.</p>
      <div class="bf-hero__cta">
        <a class="bf-btn bf-btn--primary is-on-dark" href={joinUrl} target="_blank" rel="noopener" data-pricing-modal>Join the community now</a>
      </div>
      <div class="bf-hero__trust">
        <span class="bf-hero__trust-source">Recommended by</span>
        <span class="bf-hero__trust-stars">
          <svg class="bf-star" viewBox="0 0 24 24"><path d="M12 2l3 7 7 .8-5 5 1.5 7-6.5-3.5L5 22l1.5-7-5-5L8.5 9z"/></svg>
          <svg class="bf-star" viewBox="0 0 24 24"><path d="M12 2l3 7 7 .8-5 5 1.5 7-6.5-3.5L5 22l1.5-7-5-5L8.5 9z"/></svg>
          <svg class="bf-star" viewBox="0 0 24 24"><path d="M12 2l3 7 7 .8-5 5 1.5 7-6.5-3.5L5 22l1.5-7-5-5L8.5 9z"/></svg>
          <svg class="bf-star" viewBox="0 0 24 24"><path d="M12 2l3 7 7 .8-5 5 1.5 7-6.5-3.5L5 22l1.5-7-5-5L8.5 9z"/></svg>
          <svg class="bf-star" viewBox="0 0 24 24"><path d="M12 2l3 7 7 .8-5 5 1.5 7-6.5-3.5L5 22l1.5-7-5-5L8.5 9z"/></svg>
        </span>
        <span>1,000+ Traders</span>
      </div>
    </div>
    {/* VSL combined into the hero: the click-to-play Vimeo card sits directly
        below the hero copy as one unit (was a separate band below). */}
    <div class="bf-comm-testi-wrap">
      <article class="bf-comm-testi">
        <button class="bf-comm-testi__thumb" type="button" data-bf-vimeo="1114053984" data-bf-wide aria-label="Play testimonial video">
          <img src="/assets/664a5b263659c7265be280ad/664a67e526974fa9873cf4b0_home%20images-6.webp" fetchpriority="high" alt="Community testimonial video cover" />
          <span class="bf-comm-testi__play" aria-hidden="true">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 5v14l11-7z" fill="currentColor"/></svg>
          </span>
        </button>
      </article>
    </div>
  </div>
</section>

{/* =========================================================================
    NEVER SLEEPS — the community's daily pillars, in the homepage's clean white
    card-grid language (matched section). Replaces the old off-brand full-bleed
    orange grainient CTA, which has no equivalent on the homepage.
    ========================================================================= */}
{/* Homepage-style white→light fade across the first two content sections after
    the hero (mirrors the homepage .bf-bento-fade). */}
<div class="bf-comm-fade">
<section class="bf-section bf-comm-pillars">
  <div class="bf-container">
    <div class="bf-section-header is-center">
      <span class="bf-eyebrow">Learn, trade, win every day</span>
      <h2 class="bf-h2">A trading community that never sleeps</h2>
      <p class="bf-lead">This is a full options trading community, active every day. Members share setups, alerts, and feedback from the open to the close.</p>
    </div>
    <div class="bf-community-grid">
      <div class="bf-community__media">
        <img src="/assets/664a5b263659c7265be280ad/68540f8f0903fae1504f6a44_SS.webp" alt="The Bill Fanter trading community live on Discord" loading="lazy" />
      </div>
      <div class="bf-community__benefits">
        <div data-benefits-list style="display:contents">
          {pillars.map((p, i) => (
            <div class="bf-benefit">
              <div class="bf-benefit__num">{`0${i + 1}`}</div>
              <div>
                <div class="bf-benefit__title">{p.title}</div>
                <p class="bf-body" set:html={p.body}></p>
              </div>
            </div>
          ))}
        </div>
        <a class="bf-btn bf-btn--primary" href={joinUrl} target="_blank" rel="noopener" data-pricing-modal style="margin-top:8px;align-self:flex-start">Join the community now</a>
      </div>
    </div>
  </div>
</section>

{/* =========================================================================
    INSIDE THE COMMUNITY — HeroSplit-style bento of Discord screenshots (left) +
    copy about what the day-to-day inside the community actually feels like
    (right). Copy is deliberately vibe-focused, not a repeat of the pricing
    "What's included" feature list.
    ========================================================================= */}
<section class="bf-section bf-comm-inside">
  <div class="bf-container">
    <div class="bf-comm-inside__split">
      <div class="bf-comm-inside__media" aria-hidden="true">
        <div class="bf-comm-inside__card">
          <div class="bf-grainient-mount" data-grainient="comm-inside" data-color1="#1754d8" data-color2="#3b82f6" data-color3="#0b1f5c"></div>
          <div class="bf-comm-marquee">
            <div class="bf-comm-marquee__row">
              {[...winningTrades, ...winningTrades].map((src) => (
                /* Not loading="lazy": iOS Safari won't trigger lazy-load for
                   images inside this animated, absolutely-positioned,
                   overflow-hidden marquee, so the shots collapsed to empty
                   bordered cards. Small fixed set of 4 -> load them up front. */
                <div class="bf-comm-marquee__shot"><img src={src} alt="" /></div>
              ))}
            </div>
          </div>
        </div>
      </div>
      <div class="bf-comm-inside__copy">
        <span class="bf-eyebrow">Inside the Discord</span>
        <h2 class="bf-h2">What it's actually like inside the community</h2>
        <p class="bf-lead" style="margin-top:22px">From the opening bell to the after-hours recap, the Discord is always buzzing. Traders post their entries and exits in real time, break down setups together, and back each other up on the red days. It feels less like a course and more like a trading desk you can pull up a chair to any time.</p>
        <div class="bf-hero__cta" style="margin-top:28px">
          <a class="bf-btn bf-btn--primary" href={joinUrl} target="_blank" rel="noopener" data-pricing-modal>Join the community now</a>
        </div>
      </div>
    </div>
  </div>
</section>

{/* Student reviews — the shared homepage Reviews component (video cards +
    screenshot wall), used site-wide for a single consistent reviews section. */}
<Reviews showCta={false} />
  </div>
{/* /white→grey fade band (spans "never sleeps" → Inside → Reviews) */}


{/* =========================================================================
    HOW IT WORKS — on white now (the fade band above ends at Reviews).
    ========================================================================= */}
<section class="bf-section">
  <div class="bf-container">
    <div class="bf-section-header is-center">
      <h2 class="bf-h2">How it works</h2>
    </div>
    <div class="bf-howit">
      <div class="bf-howit__step">
        <div class="bf-howit__copy">
          <h3 class="bf-h3 bf-howit__title">Learn from live trade alerts and daily analysis</h3>
          <p class="bf-body bf-howit__body">Every morning, Bill and his analysts share what they are watching and when they plan to buy or sell.</p>
        </div>
        <div class="bf-howit__media">
          <div class="bf-grainient-mount" data-grainient="howit-1" data-color1="#FF8308" data-color2="#EF4444" data-color3="#6B3BD5"></div>
          <img src="/assets/664a5b263659c7265be280ad/68554a2036b038d602bb26ec_Learn-from-Real-Time-Trade-Alerts-and-AI-Signals-(3).webp" alt="Bill Fanter's live trade alerts inside the community" loading="lazy" />
        </div>
      </div>
      <div class="bf-howit__step">
        <div class="bf-howit__copy">
          <h3 class="bf-h3 bf-howit__title">Connect with Bill and the community</h3>
          <p class="bf-body bf-howit__body">Get instant Discord access. Ask questions, share ideas, and trade alongside 1,000+ serious traders.</p>
        </div>
        <div class="bf-howit__media bf-howit__media--ticker">
          <div class="bf-grainient-mount" data-grainient="howit-2" data-color1="#FF8308" data-color2="#EF4444" data-color3="#6B3BD5"></div>
          <img src="/assets/664a5b263659c7265be280ad/68554a3a7298b4672c32b45a_Connect-with-Bill-and-a-Thriving-Community-(2).webp" alt="Connect with Bill and a Thriving Community" loading="lazy" />
          <div class="fw-ticker" aria-hidden="true">
            <div class="fw-ticker__row">
              <div class="fw-ticker__track fw-ticker__track--ltr">
                {[...tickerA, ...tickerA].map(([sym, chg, dir]) => (
                  <span class="fw-ticker__chip"><span class="fw-ticker__sym">{sym}</span><span class={`fw-ticker__chg fw-ticker__chg--${dir}`}>{chg}</span></span>
                ))}
              </div>
            </div>
            <div class="fw-ticker__row">
              <div class="fw-ticker__track fw-ticker__track--rtl">
                {[...tickerB, ...tickerB].map(([sym, chg, dir]) => (
                  <span class="fw-ticker__chip"><span class="fw-ticker__sym">{sym}</span><span class={`fw-ticker__chg fw-ticker__chg--${dir}`}>{chg}</span></span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="bf-howit__step">
        <div class="bf-howit__copy">
          <h3 class="bf-h3 bf-howit__title">Build your skill and confidence</h3>
          <p class="bf-body bf-howit__body">Follow Bill's risk rules, trade with him live, and build the discipline to trade options with a plan.</p>
        </div>
        <div class="bf-howit__media">
          <div class="bf-grainient-mount" data-grainient="howit-3" data-color1="#FF8308" data-color2="#EF4444" data-color3="#6B3BD5"></div>
          <img src="/assets/664a5b263659c7265be280ad/68554a4edca41e9e9ce967e7_Build-Your-Skill-and-Confidence-(1).webp" alt="Build Your Skill and Confidence" loading="lazy" />
        </div>
      </div>
    </div>
    <div class="bf-howit__cta">
      <a class="bf-btn bf-btn--primary" href={joinUrl} target="_blank" rel="noopener" data-pricing-modal>Join the community now</a>
    </div>
  </div>
</section>

{/* Community membership pricing (shared component — Whop URLs intact). The
    "What you get as a member" benefits are folded into the pricing cards. */}
<CommunityPricing />

{/* =========================================================================
    MEET BILL — canonical AboutBill 50/50, now placed BELOW the pricing cards.
    ========================================================================= */}
<section class="bf-section">
  <div class="bf-container">
    <div class="bf-about-grid">
      <div class="bf-about__media">
        <img src="/assets/664a5b263659c7265be280ad/664c28d7ea8baa25095372ee_masterclass%20image-1.webp" alt="Image of Bill Fanter" />
        <Signature class="bf-about__sig" />
      </div>
      <div class="bf-about__copy">
        <span class="bf-eyebrow">Your trading mentor</span>
        <h2 class="bf-h2" style="margin-top:24px">Meet Bill Fanter</h2>
        <p style="margin-top:28px">Bill Fanter spent 35+ years in banking and the markets, and he now trades options every morning around the open. He has taught 1,200+ students how options work, how to manage risk, and how to run a repeatable routine. He built this community to give traders the same daily prep, alerts, and feedback he relies on himself.</p>
        <div class="bf-about__actions">
          <a class="bf-btn bf-btn--primary" href={joinUrl} target="_blank" rel="noopener" data-pricing-modal>Join the community now</a>
        </div>
      </div>
    </div>
  </div>
</section>

{/* =========================================================================
    FAQ — bf-* styled accordion on a soft band.
    ========================================================================= */}
<section class="bf-section is-soft">
  <div class="bf-container">
    <div class="bf-section-header is-center">
      <span class="bf-eyebrow">FAQ</span>
      <h2 class="bf-h2">Frequently asked questions</h2>
    </div>
    <div class="bf-faq">
      {faqs.map((f) => (
        <details class="bf-faq__item">
          <summary>{f.q}</summary>
          <div class="bf-faq__answer">{f.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>

{/* The closing block (testimonial + Book-a-Call) is supplied globally by the
    shared Footer (Closing.astro), so this page does NOT render its own — that
    was duplicating the closing/footer. */}

{/* Simple pricing pop-up — the "Join the community" buttons open this; each
    option links straight to its Whop checkout. */}
<div class="bf-pmodal" id="bf-pmodal" aria-hidden="true">
