  '/assets/664a5b263659c7265be280ad/6877483d87e5102dd253d678_first-img.webp',
  '/assets/664a5b263659c7265be280ad/6876280f41314377162178d2_image.webp',
  '/assets/664a5b263659c7265be280ad/6876280fb21bf8e812573d1b_image%20(5)%20(1).webp',
];

// Production community reviews — verbatim quotes + real attributions.
const reviews = [
  {
    quote: "Hi Team! I've completed the Learn on You Own Masterclass from Bill, and decided to join the Discord community here. I've only joined a week or so ago, but I gotta say, I may have underestimated the value of COMMUNITY with regards to trading. It is awesome that the more experienced traders will post their own analysis and trades they are making, which definitely helps less experienced folks like myself gain some confidence. It's also great seeing everyone ROOT for each other. I have a day job, but I do aspire to become “W2 Optional” one day, after building trading skills and stacking wins.",
