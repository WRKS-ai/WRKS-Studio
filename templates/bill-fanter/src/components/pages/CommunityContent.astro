  /* FAQ uses the canonical global .bf-faq accordion (clean bordered rows with a
     +/- toggle) — same as the masterclass page. No scoped override here. */

  /* ── Pricing pop-up ─────────────────────────────────────────────────────── */
  .bf-pmodal { position: fixed; inset: 0; z-index: 1000; display: none; align-items: center; justify-content: center; padding: 24px; }
  .bf-pmodal.is-open { display: flex; }
  /* Neutral dark tint (no blue) + the SAME 5px blur as the nav dropdown backdrop. */
  .bf-pmodal__overlay { position: absolute; inset: 0; background: rgba(10, 10, 10, 0.62); -webkit-backdrop-filter: blur(5px); backdrop-filter: blur(5px); }
  .bf-pmodal__card { position: relative; width: 100%; max-width: 440px; background: #fff; border-radius: 12px; padding: 28px; box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.5); }
  .bf-pmodal__close { position: absolute; top: 16px; right: 16px; width: 32px; height: 32px; border-radius: 50%; border: 0; background: rgba(10, 10, 10, 0.06); color: #0a0a0a; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 150ms; }
  .bf-pmodal__close:hover { background: rgba(10, 10, 10, 0.12); }
