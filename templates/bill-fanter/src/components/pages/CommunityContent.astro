// Whop checkout for the direct "Join the Community Now" button (production).
const joinUrl = 'https://whop.com/checkout/1ddAafJSDTQajCsTPH-nNmX-Fcbn-qisW-UgMERKflbcdf/';
const star = '<path d="M12 2l3 7 7 .8-5 5 1.5 7-6.5-3.5L5 22l1.5-7-5-5L8.5 9z"/>';

// Decorative ticker chips (two rows, opposite directions) overlaid on the top
