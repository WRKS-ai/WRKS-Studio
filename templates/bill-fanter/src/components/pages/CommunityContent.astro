  {
    quote: "Bill Fanter, I can only confirm what others are saying in the Discord. This trading community is incredibly powerful for learning a skill that's become a real passion for me.",
    name: 'Stijn Ceelen', initial: 'S',
  },
  {
    quote: "Great community that is always willing to help one another out. I love that Bill is constantly interacting with the members and answering questions!",
    name: 'John Sammons', initial: 'J',
  },
];

// Production "reviews_static" screenshot wall — real WhatsApp images + member
// screenshots ported verbatim from the live /community page (class
// "static_reviews-images"). Rendered as a 2-col masonry like the homepage wall.
const reviewShots = [
  '/assets/664a5b263659c7265be280ad/693619fe0c4897712052fd70_WhatsApp%20Image%202025-12-08%20at%2012.41.33%20AM%20(3).webp',
  '/assets/664a5b263659c7265be280ad/693619fec6c7514bb589c309_WhatsApp%20Image%202025-12-08%20at%2012.41.33%20AM.webp',
  '/assets/664a5b263659c7265be280ad/693619feb4b6f8e17523d520_WhatsApp%20Image%202025-12-08%20at%2012.41.33%20AM%20(2).webp',
  '/assets/664a5b263659c7265be280ad/66d5a2c88eb566d3ed69ce45_16.webp',
  '/assets/664a5b263659c7265be280ad/693619fe8231380688f4eafe_WhatsApp%20Image%202025-12-08%20at%2012.41.33%20AM%20(1).webp',
  '/assets/664a5b263659c7265be280ad/68e5a2958f2a94f22caf2a25_Screenshot%202025-10-05%20at%203.53.45%E2%80%AFPM.webp',
];

// "What you get as a member" — the production benefit list, re-homed into the
// homepage Community (image + numbered benefits) pattern. Bodies added so the
// rows match the homepage rhythm and feed the AnimatedList island.
const memberBenefits = [
  { num: '01', title: 'Instant Discord access connect and learn daily', body: 'Join a community of like-minded individuals who are there to educate, support, and help you succeed from the start.' },
  { num: '02', title: 'Live buy and sell signals', body: 'Get live buy and sell signals from professional market analysts as setups form.' },
  { num: '03', title: 'AI trade signals', body: 'Use the community AI signals to spot setups faster, alongside the live alerts from Bill and his analysts.' },
  { num: '04', title: 'One-on-one coaching options', body: 'Go deeper with personal coaching tailored to where you are in your trading journey.' },
  { num: '05', title: 'Access to exclusive trading tools and layouts', body: 'Trade with the same tools, layouts, and daily market intel the pros use.' },
  { num: '06', title: 'Monthly giveaways and member-only events', body: 'Stay engaged with member-only events and monthly giveaways for the community.' },
