---
<!-- ============================================================
     HERO + BENTO STAGE — dark dot-grid zone (mirrors the other subpage
     heroes); the DotGrid spans the hero + bento behind the content.
     ============================================================ -->
<div class="bf-stage mc-stage">
  <div class="mc-stage__dots" data-dotgrid data-dot-size="2" data-gap="10" data-base-color="#454545" data-active-color="#75B5FF" data-proximity="140" data-return-duration="0.6"></div>
  <section class="bf-section bf-hero">
    <div class="bf-container">
      <div class="bf-hero__inner">
        <div class="bf-hero__eyebrow"><span class="bf-eyebrow">Attention professionals, entrepreneurs and those seeking wealth</span></div>
        <h1 class="bf-h1 bf-hero__h1">Learn the easiest options strategies for everyone in 6 live sessions</h1>
        <p class="bf-lead bf-hero__lead">Join Bill Fanter's 6-session options trading Masterclass and learn the core strategies he uses in the market. Every session is live and hands-on, built so new traders and experienced traders can follow along and trade with a plan.</p>
        <div class="bf-hero__cta">
          <a class="bf-btn bf-btn--primary is-on-dark" href="/contact">Get the masterclass</a>
        </div>
        <div class="bf-hero__trust">
          <span class="bf-hero__trust-source">Recommended by</span>
          <span class="bf-hero__trust-stars">
            {Array.from({ length: 5 }).map(() => (
              <svg class="bf-star" viewBox="0 0 24 24" set:html={star} />
            ))}
          </span>
          <span>1,600+ Students</span>
        </div>
      </div>
    </div>
  </section>

  <section class="bf-bento">
    <div class="bf-bento__grid">
      <div class="bf-bento__tile bf-bento__tile--portrait mc-bento-photo">
        <img src="/assets/664a5b263659c7265be280ad/664a67e526974fa9873cf4b0_home%20images-6.webp" alt="Image of bill fanter" fetchpriority="high" style="width:100%;height:100%;object-fit:cover;object-position:70% center" />
        <div class="mc-bento-tags" aria-hidden="true">
          <span class="mc-bento-tag">35-year finance pro; $10B+ overseen</span>
          <span class="mc-bento-tag">800+ students taught</span>
          <span class="mc-bento-tag">1,000+ traders in our community</span>
        </div>
        <Signature class="mc-bento-sig" />
      </div>
      <div class="bf-bento__tile bf-bento__tile--product bf-grainient-host mc-bento-grain">
        <div class="bf-grainient-mount" data-grainient="masterclass-bento" data-color1="#1754d8" data-color2="#3b82f6" data-color3="#0b1f5c"></div>
        <div class="fw-ticker" aria-hidden="true">
          <div class="fw-ticker__row">
            <div class="fw-ticker__track fw-ticker__track--ltr">
              {[...tickerA, ...tickerA].map(([sym, chg, dir]) => (
                <span class="fw-ticker__chip"><span class="fw-ticker__sym">{sym}</span><span class={`fw-ticker__chg fw-ticker__chg--${dir}`}>{chg}</span></span>
              ))}
            </div>
          </div>
          <div class="fw-ticker__row">
            <div class="fw-ticker__track fw-ticker__track--rtl">
              {[...tickerB, ...tickerB].map(([sym, chg, dir]) => (
                <span class="fw-ticker__chip"><span class="fw-ticker__sym">{sym}</span><span class={`fw-ticker__chg fw-ticker__chg--${dir}`}>{chg}</span></span>
              ))}
            </div>
          </div>
        </div>
        <img class="mc-bento-device" src="/assets/664a5b263659c7265be280ad/664c28d718c7d550c67838bb_masterclass%20image-2.webp" alt="" aria-hidden="true" loading="lazy" />
      </div>
      <div class="bf-bento__tile bf-bento__tile--quote">
        <p class="bf-bento__quote-text">&ldquo;I can't say enough about Bill Fanter! This masterclass was a true eye-opener. As a former financial advisor, I learned things in Bill's class that I never had before, and now I have the skills to provide a lifetime of return.&rdquo;</p>
        <div class="bf-bento__quote-footer">
          <div class="bf-bento__quote-author">
            <div class="bf-bento__quote-name">Dan Funderburk, MBA</div>
            Executive Recruiting at H-E-B
          </div>
          <a class="bf-bento__quote-link" href="/student-comments">Read more reviews <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </div>
  </section>
</div>
<!-- /STAGE -->

{/* "Options trading strategies that make sense to anyone" — the HeroSplit media
    bento carrying the masterclass copy, with the Simple / Effective / Easy tiles
    right below it. */}
<HeroSplit
  eyebrow={null}
  heading="Options trading strategies that make sense to anyone"
  lead="You do not need a finance background to trade options with a plan. Bill breaks the market into clear, repeatable steps and shows you how he reads setups, defines risk, and places trades. New traders get a starting point. Experienced traders sharpen what they already do."
  ctaLabel="Get the masterclass"
  ctaHref="/contact"
>
  {/* Simple / Effective / Easy trio as icon cards, rendered inside the HeroSplit
      section/container right below the media+copy (identical to the shared
      HelpGrid: black icon chip, no hover). */}
  <div class="mc-learn-grid bf-help-grid--three">
    {learnCards.map((c) => (
      <div class="bf-help-card">
        <div class="bf-help-card__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon} />
        </div>
        <div class="bf-help-card__title">{c.title}</div>
        <p class="bf-body">{c.body}</p>
      </div>
    ))}
  </div>
</HeroSplit>

{/* WHAT YOU'LL LEARN over 6 sessions — the curriculum laid over the blue
    GridDistortion spotlight card (same treatment as the free-webinar card),
    moved ABOVE pricing so it builds value before the buyer sees the price. */}
<div class="mc-learn-spotlight">
  <section class="bf-spotlight">
    <div class="bf-spotlight__card bf-spotlight__card--simple">
      <div data-griddistortion data-image="/assets/sandbox/webinar-distortion.webp?v=2" class="bf-spotlight__distortion"></div>
      <div class="bf-spotlight__overlay"></div>
      <div class="bf-spotlight__content mc-learn-spotlight__content">
        <h2 class="bf-spotlight__h2 mc-learn-spotlight__h2">Here's what you'll learn over 6 live training sessions</h2>
        <div class="mc-learn-spotlight__grid">
          {sessionPoints.map((p, i) => (
            <div class="mc-learn-spotlight__item">
              <div class="mc-learn-spotlight__num">{String(i + 1).padStart(2, '0')}</div>
              <p class="mc-learn-spotlight__desc">{p}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</div>

{/* SUCCESS STORIES — Reviews on a neutral-grey fade band. */}
<div class="mc-reviews-band">
  <Reviews showCta={false} />
</div>

{/* WHY BILL — authority beat right before pricing (EffortlessStrategy layout).
    Carries the neutral-grey fade band (moved off the Reviews section). */}
<div class="mc-whybill-band">
  <EffortlessStrategy
    heading="A simple routine, built on real strategy"
    lead="Bill keeps the routine simple so you can stay consistent. You learn what to watch, how to size each trade, and when to step back. The strategy underneath is the same one he runs in the market every day, drawn from 35+ years in banking and the markets."
    ctaHref="/contact"
    ctaLabel="Get the masterclass"
    features={[
      { lead: 'Keep the routine simple', rest: ': trade a focused window, then step away and get on with your day.' },
      { lead: 'Trade with a plan', rest: ': know your entry, exit, and risk before you place a trade.' },
      { lead: 'Build real skill', rest: ': learn the setups and rules you can run on your own over time.' },
    ]}
  />
</div>

{/* COMMUNITY — the Discord community included with the Masterclass. CTA routes
    to the Masterclass pricing (not /community), since the room is part of this offer. */}
<Community
  ctaHref="/contact"
  ctaLabel="Get the masterclass"
  heading="The Masterclass includes access to my daily trading community"
  lead="Your sessions teach the strategy. The community keeps you in the market every day, with live alerts, shared setups, and direct access to Bill. Here's what's included:"
/>

<!-- ============================================================
     PRICING — the decision, with a de-risk line above the cards.
     ============================================================ -->
<section class="bf-section mc-band mc-band--pricing" id="pricing">
  <div class="mc-pricing-dots" data-dotgrid data-dot-size="2" data-gap="10" data-base-color="#454545" data-active-color="#75B5FF" data-proximity="140" data-return-duration="0.6"></div>
  <div class="bf-container">
    <div class="bf-pricing__intro">
      <span class="bf-eyebrow">Join our masterclass</span>
      <h2 class="bf-h2" style="margin-top:20px">Choose your path to trading mastery</h2>
      <p class="bf-lead">Every student starts in a practice simulator with paper money, so you build the skill before you risk real capital.</p>
    </div>
    <div class="bf-blueprint-grid">
      <div class="bf-price-card">
        <div>
          <div class="bf-price-card__name">Masterclass (Foundation)</div>
        </div>
        <div>
          <div class="bf-price-card__included-label">What's included?</div>
          <ul class="bf-price-card__list" style="margin-top:14px">
            {foundationFeatures.map((f) => <li>{f}</li>)}
          </ul>
        </div>
        <a class="bf-btn bf-btn--primary bf-price-card__cta" href="/contact">Contact us</a>
      </div>
      <div class="bf-price-card bf-price-card--featured">
        <div>
          <div class="bf-price-card__name">Masterclass Pro (Mastery)</div>
        </div>
        <div>
          <div class="bf-price-card__included-label">What's included?</div>
          <ul class="bf-price-card__list" style="margin-top:14px">
            {proFeatures.map((f) => <li>{f}</li>)}
          </ul>
        </div>
        <a class="bf-btn bf-price-card__cta" href="/contact">Contact us</a>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     FAQ — bf-* accordion (homepage-quality), 14 questions.
     ============================================================ -->
<section class="bf-section mc-band mc-band--soft" id="FAQ">
  <div class="bf-container">
    <div class="bf-section-header is-center">
      <h2 class="bf-h2">Frequently asked questions</h2>
    </div>
    <div class="bf-faq">
      {faqs.map((item) => (
        <details class="bf-faq__item">
          <summary>{item.q}</summary>
          <div class="bf-faq__answer" set:html={item.a}></div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- ============================================================
     MEMBERSHIP CTA — the homepage's black YoutubeCta variant
     (.bf-darkcta--black): black panel, copy left, a contained
     grainient square with the image floated over it on the right.
     Copy + image + #pricing2 link preserved.
     ============================================================ -->
<section class="bf-section is-tight">
  <div class="bf-container">
    <div class="bf-darkcta bf-darkcta--black">
      <div class="bf-darkcta__grid">
        <div>
          <h2 class="bf-darkcta__h2">Ready to explore options trading?</h2>
          <p class="bf-darkcta__lead">Take the next step and learn the strategies Bill uses in the market. Get the Masterclass and trade with a plan, real risk rules, and a community behind you.</p>
