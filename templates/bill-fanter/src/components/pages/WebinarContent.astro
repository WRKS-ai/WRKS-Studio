<!-- Meet Bill Fanter — homepage AboutBill 50/50 split. The blue band continues
     through here and ENDS at the bottom of this section (CTA below is on white). -->
<section class="bf-section">
  <div class="bf-container">
    <div class="bf-about-grid">
      <div class="bf-about__media">
        <img
          src="/assets/664a5b263659c7265be280ad/664c28d7ea8baa25095372ee_masterclass%20image-1.webp"
