  }}
  features={[
    { lead: 'Click buy or sell with a plan', rest: ': know your entry, exit, and stop before every trade.' },
    { lead: 'Cap your downside to the dollar', rest: ': set your maximum loss per trade up front.' },
    { lead: 'Trade one focused hour, then log off', rest: ': handle the open in the morning and get your day back.' },
    { lead: 'Aim for asymmetric setups', rest: ' where the upside outweighs the risk you define going in.' },
