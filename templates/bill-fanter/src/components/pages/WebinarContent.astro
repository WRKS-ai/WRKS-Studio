---
// /webinar page body — rebuilt as a CLONE of the homepage's design language.
// Every section now uses the same bf-* homepage patterns (alternating
// white / var(--bf-bg-2) bands, --bf-section-pad rhythm, .bf-container,
// .bf-h2 / .bf-lead, 50/50 .bf-about-grid splits, .bf-help-grid even card
// grids, the Reviews video+wall pattern, and the .bf-darkcta grainient CTA)
// so /webinar matches homepage quality.
//
// CONTENT is preserved VERBATIM from the prior production /webinar page: every
// heading, paragraph, list item, button label, image src/srcset, the
// registration form (attributes untouched), the Whop community link, the 8
// reviews (names + titles), and the disclaimer. Only the old non-homepage
// section wrappers/styles were swapped for homepage-style sections — no copy
// was dropped, reworded, summarized, or invented.
//
// The hero (with the reserve-your-spot form) is kept EXACTLY as-is. Grainient
// fills (webinar-form / webinar-darkcta) are mounted by the Islands script.
import Reviews from '../sections/Reviews.astro';
import SubscribeForm from '../SubscribeForm.astro';
import EffortlessStrategy from '../sections/EffortlessStrategy.astro';
import Signature from '../Signature.astro';
const star = '<path d="M12 2l3 7 7 .8-5 5 1.5 7-6.5-3.5L5 22l1.5-7-5-5L8.5 9z"/>';

// Reviews — homepage pattern (verbatim quotes, names, titles, image srcs).
const A = '/assets/664a5b263659c7265be280ad/';
const reviews = [
  { name: 'Alex Pitcaithly', title: 'Dynamic People Leader', img: `${A}679c4c1c4e9c2e629f9dabd4_alex-pitcaithly.webp`, quote: "I just completed Bill Fanter's Options Masterclass; it was a great introduction to trading options and an overall enjoyable experience. Thank you, Bill, for sharing your knowledge, looking forward to your continued mentoring and friendship. If you want to learn about the options market from someone who is a successful trader and passionate to share his skills, then I highly recommend Bill's Masterclass." },
  { name: 'Dan Funderburk, MBA', title: 'Executive Recruiting at H-E-B', img: `${A}679c4f04407a54b6277c94f3_dan-funderburk.webp`, quote: "I can't say enough about Bill Fanter! This masterclass was a true eye-opener. As a former financial advisor in a previous life, I learned things in Bill's class that I never had before. I had limited, cursory knowledge of the markets, charting, and supply & demand, but now I have the skills, albeit very green, to provide a lifetime of return. And the education doesn't stop with the class. There is a community of like-minded traders, all ready and willing to help and lend a hand. I'm super thankful for this opportunity and look forward to the journey ahead." },
  { name: 'Danielle G', title: 'Sr. Epic Application Specialist', img: `${A}679c4ad9a63b20955c05a779_danielle-g.webp`, quote: "Do not wait to get involved! Bill's master class is highly informative and so well presented. He is an expert with knowledge beyond what most traders have and is incredibly responsive with questions. I cannot say enough about this class nor the incredible trading community Bill has created. You will see returns in multiple forms, not just monetary. With the economy frequently in question and the many uncertainties in life, securing one's financial well being is a strong priority. Why wait? LFG!!" },
  { name: 'John Gordy', title: 'Chief Financial Officer at DroneUp', img: `${A}678e77c8a0abd734e3415731_jogn-gordy.avif`, imgAlt: 'John Gordy profile image', quote: "Thank you Bill for your mentorship! I'm a huge advocate of your patient & disciplined approach to trading. Learning the correct way to identify & trade liquidity while managing risk is a valuable skill that can be lifechanging when executed properly!" },
  { name: 'Riley H', title: 'Sales Specialist at AB Laboratories Inc.', img: `${A}678e7871274732ce809d928f_riley-h.avif`, imgAlt: 'Riley H profile image', quote: "It was an absolute joy learning from Bill. The brightest people can take complex ideas and explain them with simplicity. Bill certainly exemplifies this. I'm very much looking forward to continuing to grow my knowledge alongside the great community Bill has created. Thank you for your time Bill, it's much appreciated!" },
  { name: 'Stijn Ceelen', title: 'Seasoned C-level leader in Banking & Wealth(Tech)', img: `${A}678e78e0ad106cbe59c5e816_stijn-ceelen.avif`, imgAlt: 'Stijn Ceelen profile image', quote: "Just wrapped up the masterclass in options trading with Bill Fanter, and I have to say, I absolutely loved it! This old fox (me) picked up some new tricks, proving once again that life always has more to teach you. A big thank you to Bill Fanter for being not just a great teacher, but also a fantastic person and mentor. Your insights and approach make all the difference! Now, time to put your lessons into action 🚀" },
  { name: 'Rob Stalkie', title: 'Account Manager', img: `${A}679c51ea7d9046f26ec04264_rob-stalkie.webp`, quote: "Bill's Masterclass was incredibly informative and fun. He weaves in and out of topics from trading psychology to charting and makes every lesson accessible to complete beginners. Well worth it!" },
  { name: 'David Lawson', title: 'Founder Icegreen - Beautiful Bags For Brands', img: `${A}678e7a667540897023632d1b_david-lawson.avif`, imgAlt: 'David Lawson profile image', quote: "I just finished taking Bill Fanter's Master Class. It has been an amazing experience. Bill teaches a complex subject and presents it in a way that is easy to process and understand. I feel very grateful to come across Bill and this opportunity. He has big heart and cares about his students. I would highly recommend this course if you have an interest in trading options. Thank you very much Bill for what you have put into this, I look forward to learning and working with in the future." },
];

// Discord / chat screenshot wall — verbatim sources from the prior page.
const shots = [
  { src: `${A}693619fe0c4897712052fd70_WhatsApp%20Image%202025-12-08%20at%2012.41.33%20AM%20(3).webp`, alt: '' },
  { src: `${A}693619fec6c7514bb589c309_WhatsApp%20Image%202025-12-08%20at%2012.41.33%20AM.webp`, alt: '' },
  { src: `${A}693619feb4b6f8e17523d520_WhatsApp%20Image%202025-12-08%20at%2012.41.33%20AM%20(2).webp`, alt: '' },
  { src: `${A}66d5a2c88eb566d3ed69ce45_16.webp`, alt: '' },
  { src: `${A}693619fe8231380688f4eafe_WhatsApp%20Image%202025-12-08%20at%2012.41.33%20AM%20(1).webp`, alt: '' },
  { src: `${A}68e5a2958f2a94f22caf2a25_Screenshot%202025-10-05%20at%203.53.45%E2%80%AFPM.webp`, alt: '' },
