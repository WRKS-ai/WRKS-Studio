<style>
  /* ============================================================
     /webinar scoped polish — homepage clone. Only minimal layout
     glue lives here; the heavy lifting comes from the homepage
     bf-* component classes in bf-design-system.css (untouched).
     ============================================================ */

  /* Alternating off-white band, same token the homepage uses between
     white sections so the page reads as composed bands. */
  /* Fade the band into white at its top + bottom edges so consecutive
     white / band sections blend instead of reading as hard grey/white steps. */
  .is-band { background: linear-gradient(180deg, #ffffff 0%, var(--bf-bg-2) 14%, var(--bf-bg-2) 86%, #ffffff 100%); }

  /* "Before you place" sits on plain white now; the gradient band STARTS lower,
     at the reviews (hard #eef4fc top edge) and fades to white by the bottom of
     the reviews. The reviews section goes transparent so the band shows through. */
  /* First band on the page → GREY, oriented white-top → colour-bottom (homepage
     style). The blue band comes second (.bf-webinar-fade2). */
  .bf-webinar-fade { background: linear-gradient(180deg, #ffffff 0%, #f4f4f7 100%); }
  .bf-webinar-fade :global(.bf-reviews) { background: transparent; }

  /* "Before you place" headline → content gap: drop the shared .bf-community-grid
     64px margin-top so the gap is just the section-header rhythm (was a doubled
     ~120px). */
  .bf-community-grid { margin-top: 0; }

  /* Second fade: hard NEUTRAL off-white top edge at "Meet Bill Fanter", fading to
     white by the bottom of the final CTA (the first band above uses the cool
     #eef4fc tint, so the page shows two distinct fades, not all blue). Wraps
     "Meet Bill Fanter" + the closing CTA — all transparent so the band shows. */
  /* Second band on the page → BLUE, oriented white-top → colour-bottom. */
  .bf-webinar-fade2 { background: linear-gradient(180deg, #ffffff 0%, #eef4fc 100%); }
  .bf-webinar-fade2 .bf-section { background: transparent; }

  /* Blue band across "The habits…" + "This webinar is for you if" — white top
     fading to blue by the bottom (the page's white→colour orientation). The
     wrapped EffortlessStrategy + .bf-section go transparent so the band shows. */
  .bf-webinar-fade3 { background: linear-gradient(180deg, #ffffff 0%, #eef4fc 100%); }
  .bf-webinar-fade3 .bf-section { background: transparent; }
  .bf-webinar-fade3 :global(.es-section) { background: transparent; }

  /* ── Closing-CTA tickers: two rows of stock chips scrolling opposite ways,
     centered over the grainient square (same concept as /free-watchlist). ────── */
  .fw-ticker {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 12px;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 14%, #000 86%, transparent 100%);
    mask-image: linear-gradient(90deg, transparent 0%, #000 14%, #000 86%, transparent 100%);
  }
  .fw-ticker__row { display: flex; overflow: hidden; }
  .fw-ticker__track { display: inline-flex; flex: 0 0 auto; white-space: nowrap; will-change: transform; }
  .fw-ticker__track--ltr { animation: fw-ticker-ltr 26s linear infinite; }
  .fw-ticker__track--rtl { animation: fw-ticker-rtl 26s linear infinite; }
  @keyframes fw-ticker-ltr { from { transform: translateX(0); } to { transform: translateX(-50%); } }
