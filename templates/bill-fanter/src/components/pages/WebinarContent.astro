<section class="bf-section">
  <div class="bf-container">
    <div class="bf-darkcta bf-darkcta--black">
      <div class="bf-darkcta__grid">
        <div>
          <h2 class="bf-darkcta__h2">Ready to trade the opening hour with a plan?</h2>
