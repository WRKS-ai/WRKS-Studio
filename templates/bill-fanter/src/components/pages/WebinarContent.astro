// "Before you place another trade" feature cards (verbatim).
const features = [
  { icon: `${A}664a67e395a23dde11b86219_home%20images.svg`, title: 'Control more of the move for less', body: 'Learn how a small options premium gives you exposure that usually takes a much larger stock position.' },
  { icon: `${A}664a67e37d7ad83ed24c8b3c_home%20images-1.svg`, title: 'Read the opening hour', body: "Learn why the first hour shows the day's clearest moves and how to trade that window." },
