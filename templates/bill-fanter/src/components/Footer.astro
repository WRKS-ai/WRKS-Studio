---
// Global site footer — the FULL footer shown on every page: the Closing block
// (rotating reviews + Book-a-Call) followed by the dark footer columns,
// disclaimer, and copyright bar. Bundling Closing here means any page that
// renders <Footer /> gets the complete footer experience (no "partial" variant).
//
// Columns mirror the nav's dropdown organization (Join / Learn / Company),
// plus a Legal column (legal pages live only in the footer, as in the nav).
// Styling lives in bf-design-system.css (loaded globally by BaseLayout).
import Closing from './sections/Closing.astro';
---
<div class="bf-page">
  <Closing />
  <footer class="bf-footer-dark">
    <div class="bf-footer-dark__grid">
      <div>
        <a class="bf-footer-dark__brand-mark" href="/">BILL FANTER</a>
        <p class="bf-footer-dark__brand-text">Learn options trading and trade with confidence.</p>
      </div>
      <div class="bf-footer-dark__col">
        <div class="bf-footer-dark__col-title">Join</div>
        <a href="/masterclass">Masterclass</a>
        <a href="/community">Community</a>
      </div>
      <div class="bf-footer-dark__col">
        <div class="bf-footer-dark__col-title">Learn</div>
        <a href="/webinar">Free webinar</a>
        <a href="/free-watchlist">Free watchlist</a>
        <a href="/blog">Blog</a>
      </div>
      <div class="bf-footer-dark__col">
        <div class="bf-footer-dark__col-title">Company</div>
        <a href="/student-comments">Student reviews</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <a href="https://members.billfanter.com/login" target="_blank" rel="noopener">Login</a>
      </div>
      <div class="bf-footer-dark__col">
        <div class="bf-footer-dark__col-title">Legal</div>
        <a href="/privacy-policy">Privacy policy</a>
        <a href="/terms-conditions">Terms &amp; conditions</a>
        <a href="/refund-policy">Refund policy</a>
      </div>
    </div>

    <p class="bf-footer-dark__disclaimer">
      The information provided in this course is for educational purposes only and is not intended as financial advice. The strategies and techniques taught in this course are examples and should not be interpreted as specific investment advice. We do not guarantee any particular financial outcomes as a result of using this information. All trading involves risk, including the potential loss of principal. We encourage participants to consider their personal financial situation and consult with a professional advisor before making investment decisions. Participation in this course does not guarantee success in trading.
    </p>

    <div class="bf-footer-dark__bottom">
      <div>© 2026 billfanter.com &middot; Options Action LLC, Las Vegas, NV<span class="bf-footer-dark__built"><span class="bf-footer-dark__built-sep"> &middot; </span>Built by <a class="bf-footer-dark__credit" href="https://slightwrks.com" target="_blank" rel="noopener">WRKS Online</a></span></div>
      <div class="bf-footer-dark__socials">
        <a href="https://www.facebook.com/bill.fanter/" target="_blank" rel="noopener" aria-label="Facebook">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.696 4.533-4.696 1.312 0 2.686.235 2.686.235v2.97h-1.514c-1.491 0-1.956.93-1.956 1.886v2.264h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
        </a>
        <a href="https://www.instagram.com/billfanter/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
