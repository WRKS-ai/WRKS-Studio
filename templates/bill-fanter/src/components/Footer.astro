<style>
  /* Brand mark is now a link home — keep it visually identical to the heading. */
  .bf-footer-dark__brand-mark { display: inline-block; text-decoration: none; }

  /* "Built by WRKS Online" credit — a real backlink, subtly highlighted. */
  .bf-footer-dark__credit {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }
  .bf-footer-dark__credit:hover { color: #fff; }

  /* Site-wide financial disclaimer — lives in the footer so every page carries
     it. Contained to the footer content width with a subtle separator above. */
  .bf-footer-dark__disclaimer {
    position: relative;
    max-width: var(--bf-container, 1440px);
    margin: 36px auto 0;
    padding: 28px 32px 0;
    font-size: 12.5px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.66);
  }
  /* Divider sits at the content width (inset by the container's side padding)
     so it lines up with the footer columns instead of running edge-to-edge of
     the 1440px box. */
  .bf-footer-dark__disclaimer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 32px;
    right: 32px;
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
  }
  @media (max-width: 768px) {
    .bf-footer-dark__disclaimer { padding-left: 20px; padding-right: 20px; }
    .bf-footer-dark__disclaimer::before { left: 20px; right: 20px; }
    /* Align every footer row to the same 20px left edge as the disclaimer, and
       left-align the copyright/socials row (was a space-between that drifted). */
    .bf-footer-dark__grid { padding-left: 20px; padding-right: 20px; }
    .bf-footer-dark__bottom {
      padding-left: 20px;
      padding-right: 20px;
      justify-content: flex-start;
    }
    /* "Built by WRKS Online" drops to its own line (without the leading middot). */
    .bf-footer-dark__built { display: block; margin-top: 4px; }
    .bf-footer-dark__built-sep { display: none; }
  }
</style>
