---
// /privacy-policy — componentized 2026 redesign (clean bf-* sections + shared
// CardNav / Footer / Islands chrome). Replaced the classic-modernized page.
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReactReady from '../../components/ReactReady.jsx';
import Islands from '../../components/Islands.astro';
import Footer from '../../components/Footer.astro';
import PrivacyPolicyContent from '../../components/pages/PrivacyPolicyContent.astro';
---
<BaseLayout
  title="Privacy Policy | Bill Fanter"
  description="Bill Fanter privacy policy."
  ogImage="/assets/664a5b263659c7265be280ad/664d79eba5d00231744cc9dd_opengraph.webp"
  wfPageId="664d8033bc5b9c7939b9971c"
>
  <ReactReady client:only="react" />
  <main class="bf-page" data-cardnav-host>
    <PrivacyPolicyContent />
  </main>
  <Footer />
  <Islands />
</BaseLayout>

<style is:global>
  main.bf-page[data-cardnav-host] { position: relative; }
</style>
