---
// /blog — componentized 2026 redesign (clean bf-* sections + shared
// CardNav / Footer / Islands chrome). Replaced the classic-modernized page.
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReactReady from '../../components/ReactReady.jsx';
import Islands from '../../components/Islands.astro';
import Footer from '../../components/Footer.astro';
import BlogContent from '../../components/pages/BlogContent.astro';
// noindex while /blog is a placeholder ("coming soon", no posts). A thin page
// in the index dilutes quality signals. Remove `noindex` and add /blog back to
// the sitemap filter once real posts ship (content phase).
---
<BaseLayout
  title="Learning Resources | Bill Fanter"
  description="Articles, tutorials, and trade breakdowns from Bill Fanter, written to help you build real options-trading skill."
  ogImage="/assets/664a5b263659c7265be280ad/664d79eba5d00231744cc9dd_opengraph.webp"
  wfPageId="664d6658b3efb6a1eb5521e0"
  noindex
>
  <ReactReady client:only="react" />
  <main class="bf-page" data-cardnav-host>
    <BlogContent />
  </main>
  <Footer />
  <Islands />
</BaseLayout>

<style is:global>
  main.bf-page[data-cardnav-host] { position: relative; }
</style>
