---
// /about — About page cloned from the homepage's design language. A stub for now
// (real bio + placeholder copy) to be fleshed out for SEO later. All the section
// patterns + alternating bands live in AboutContent. Shared CardNav / Footer /
// Islands chrome like every other page.
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReactReady from '../../components/ReactReady.jsx';
import Islands from '../../components/Islands.astro';
import Footer from '../../components/Footer.astro';
import AboutContent from '../../components/pages/AboutContent.astro';
---
<BaseLayout
  title="About | Bill Fanter"
  description="Learn, grow, and trade alongside Bill Fanter, a veteran options trader with 35+ years of investment expertise."
  ogImage="/assets/664a5b263659c7265be280ad/664d79eba5d00231744cc9dd_opengraph.webp"
  wfPageId="664a5b263659c7265be280e3"
>
  <ReactReady client:only="react" />
  <main class="bf-page" data-cardnav-host>
    <AboutContent />
  </main>
  <Footer />
  <Islands />
</BaseLayout>

<style is:global>
  main.bf-page[data-cardnav-host] { position: relative; }
</style>
