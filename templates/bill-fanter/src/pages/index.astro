---
// Homepage — componentized 2026 redesign. WRKS template: which sections
// render is driven by siteConfig (agent-curated per user). Bento fade
// wrapper stays because it's a visual continuity requirement between the
// MegaBento and Watchlist sections — it's only inserted when BOTH are
// selected; if only one is, that section renders solo without the fade.
import BaseLayout from '../layouts/BaseLayout.astro';
import ReactReady from '../components/ReactReady.jsx';
import Islands from '../components/Islands.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import MegaBento from '../components/sections/MegaBento.astro';
import Watchlist from '../components/sections/Watchlist.astro';
import Community from '../components/sections/Community.astro';
import HelpGrid from '../components/sections/HelpGrid.astro';
import Spotlight from '../components/sections/Spotlight.astro';
import HeroSplit from '../components/sections/HeroSplit.astro';
import Reviews from '../components/sections/Reviews.astro';
import YoutubeCta from '../components/sections/YoutubeCta.astro';
import AboutBill from '../components/sections/AboutBill.astro';
import { siteConfig } from '../data/siteConfig.sample';

const homeSections = siteConfig.compositions.home?.sections ?? [];
const has = (id: string) => homeSections.includes(id as never);

// The MegaBento + Watchlist share a continuous gradient fade wrapper.
// Only wrap when BOTH are selected — if the agent drops one, the other
// renders standalone.
const bentoFadeWrap = has('megaBento') && has('watchlist');
---
<BaseLayout
  title="Options Trading Masterclass, Signals & Community | Bill Fanter"
  description="Learn options trading with Bill Fanter. Get the masterclass, live trade alerts, a free stock watchlist, and a daily options trading community."
  ogImage="/assets/664a5b263659c7265be280ad/664d79eba5d00231744cc9dd_opengraph.webp"
  wfPageId="664a5b263659c7265be280e3"
>
  <ReactReady client:only="react" />
  {/* variant="split" = the narrow 57% header that meets the hero image edge. */}
  <main class="bf-page" data-cardnav-host data-cardnav-variant="split">
    {homeSections.map((id) => {
      if (id === 'hero') return <Hero />;
      if (id === 'community') return <Community />;
      if (id === 'helpGrid') return <HelpGrid />;
      if (id === 'spotlight') return <Spotlight />;
      if (id === 'heroSplit') return <HeroSplit />;
      if (id === 'reviews') return <Reviews />;
      if (id === 'youtubeCta') return <YoutubeCta />;
      if (id === 'aboutBill') return <AboutBill />;
      // MegaBento + Watchlist: rendered inside the shared fade wrapper
      // below when both are selected; skip standalone renders in that
      // case to avoid rendering them twice.
      if (id === 'megaBento' && !bentoFadeWrap) return <MegaBento />;
      if (id === 'watchlist' && !bentoFadeWrap) return <Watchlist />;
      // When bentoFadeWrap === true, the first of the pair emits the
      // wrapper with both inside; the second is a no-op.
      if (id === 'megaBento' && bentoFadeWrap) {
        return (
          <div class="bf-bento-fade">
            <MegaBento />
            <Watchlist />
          </div>
        );
      }
      if (id === 'watchlist' && bentoFadeWrap) return null;
      return null;
    })}
  </main>
  <Footer />
  <Islands />
</BaseLayout>

<style is:global>
  main.bf-page[data-cardnav-host] { position: relative; }
  /* Continuous fade spanning the bento + watchlist (their own section
     backgrounds go transparent so this one gradient shows through both). Ends
     at #f6f8fc with a hard border into the white Community section. */
  .bf-bento-fade { background: linear-gradient(180deg, #ffffff 0%, #f6f8fc 100%); }
  .bf-bento-fade .bf-mega { background: transparent; }
  .bf-bento-fade #watchlist.bf-section { background: transparent; }
</style>
