---
// /community — componentized 2026 redesign (clean bf-* sections + shared
// CardNav / Footer / Islands chrome). Replaced the classic-modernized page.
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReactReady from '../../components/ReactReady.jsx';
import Islands from '../../components/Islands.astro';
import Footer from '../../components/Footer.astro';
import CommunityContent from '../../components/pages/CommunityContent.astro';
---
<BaseLayout
  title="Join Bill Fanter's Options Trading Community | Live Trade Alerts & Mentorship"
  description="Trade options every day with Bill Fanter and 1,000+ members. Live trade alerts, daily market analysis, risk rules, and direct access to Bill. Join the community."
  ogImage="/assets/664a5b263659c7265be280ad/664d79eba5d00231744cc9dd_opengraph.webp"
  wfPageId="6853ea0693bc4b35fa48b4ff"
>
  <ReactReady client:only="react" />
  <main class="bf-page" data-cardnav-host>
    <CommunityContent />
  </main>
  <Footer />
  <Islands />
</BaseLayout>

<style is:global>
  main.bf-page[data-cardnav-host] { position: relative; }
</style>
