---
// /student-comments — componentized 2026 redesign (clean bf-* sections + shared
// CardNav / Footer / Islands chrome, incl. the roundtable video showcase).
// Replaced the classic-modernized page.
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReactReady from '../../components/ReactReady.jsx';
import Islands from '../../components/Islands.astro';
import Footer from '../../components/Footer.astro';
import StudentCommentsContent from '../../components/pages/StudentCommentsContent.astro';
---
<BaseLayout
  title="Student Reviews | Bill Fanter"
  description="Real reviews from real students of Bill Fanter's masterclass and community."
  ogImage="/assets/664a5b263659c7265be280ad/664d79eba5d00231744cc9dd_opengraph.webp"
  wfPageId="66d59f25ecf51171be5c77ae"
>
  <ReactReady client:only="react" />
  <main class="bf-page" data-cardnav-host>
    <StudentCommentsContent />
  </main>
  <Footer />
  <Islands />
</BaseLayout>

<style is:global>
  main.bf-page[data-cardnav-host] { position: relative; }
</style>
