---
// /preview — SSR route that renders the Bill-Fanter homepage with
// per-user generated content passed IN the URL query.
//
// WRKS Studio's canvas builds a URL like:
//   /preview?data=<encodeURIComponent(JSON.stringify({content, designSystem}))>

export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ReactReady from '../../components/ReactReady.jsx';
import Islands from '../../components/Islands.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/sections/Hero.astro';
import HeroSplit from '../../components/sections/HeroSplit.astro';
import HelpGrid from '../../components/sections/HelpGrid.astro';
import EffortlessStrategy from '../../components/sections/EffortlessStrategy.astro';
import AboutBill from '../../components/sections/AboutBill.astro';
import Closing from '../../components/sections/Closing.astro';
import type {
  HeroContent,
  HeroSplitContent,
  HelpGridContent,
  EffortlessStrategyContent,
  AboutBillContent,
  ClosingContent,
} from '../../data/content.schema';

type UrlPayload = {
  content: {
    pageId: string;
    title: string;
    hero: Omit<HeroContent, 'portrait'>;
    heroSplit?: Omit<HeroSplitContent, 'photo' | 'videoVimeoId'>;
    helpGrid: HelpGridContent;
    effortlessStrategy?: Omit<EffortlessStrategyContent, 'review' | 'image'>;
    about: Omit<AboutBillContent, 'photo'>;
    closing: Omit<ClosingContent, 'reviews'>;
  };
  designSystem: {
    palette: {
      primary: { hex: string };
      secondary: { hex: string };
      tertiary: { hex: string };
      neutral: { hex: string; scale: string[] };
    };
    type: {
      display: { family: string };
      body: { family: string };
      mono: { family: string };
    };
  };
};

const raw = Astro.url.searchParams.get('data');
let payload: UrlPayload | null = null;
let parseError: string | null = null;

if (raw) {
  try {
    payload = JSON.parse(decodeURIComponent(raw)) as UrlPayload;
  } catch (err) {
    parseError = err instanceof Error ? err.message : String(err);
  }
} else {
  parseError = 'Missing ?data= query param';
}

// Palette-driven gradient placeholder — data URI so it inlines with no
// asset roundtrip. Two-stop diagonal gradient over the user's primary
// hue. Replaces Bill's actual photos so a user's site doesn't render
// Bill Fanter's face on it.
function makeGradientDataUri(primary: string, secondary: string): string {
  const svg = `<svg xmlns='http://www.w3.org/2000/svg' width='800' height='1000' viewBox='0 0 800 1000'><defs><linearGradient id='g' x1='0%' y1='0%' x2='100%' y2='100%'><stop offset='0%' stop-color='${primary}'/><stop offset='100%' stop-color='${secondary}'/></linearGradient><radialGradient id='v' cx='45%' cy='40%' r='60%'><stop offset='0%' stop-color='rgba(0,0,0,0)'/><stop offset='100%' stop-color='rgba(0,0,0,0.55)'/></radialGradient></defs><rect width='800' height='1000' fill='url(%23g)'/><rect width='800' height='1000' fill='url(%23v)'/></svg>`;
  return `data:image/svg+xml;utf8,${svg}`;
}

const gradientUri = payload
  ? makeGradientDataUri(
      payload.designSystem.palette.primary.hex,
      payload.designSystem.palette.secondary.hex,
    )
  : '';

// Build FULL section content by merging user text overrides with
// placeholder images. Image slots (portrait, photo) get palette
// gradients so Bill's face never shows on a non-Bill brand. Sub-
// objects (review quote, ticker chips) stay as sample data — they'd
// otherwise crash the render.
import { content as sampleContent } from '../../data/content.sample';

const mergedHero: HeroContent | undefined = payload?.content.hero
  ? {
      ...payload.content.hero,
      portrait: { src: gradientUri, alt: '' },
    }
  : undefined;

const mergedHeroSplit: HeroSplitContent | undefined = payload?.content
  .heroSplit
  ? {
      ...payload.content.heroSplit,
      photo: { src: gradientUri, alt: '' },
      videoVimeoId: sampleContent.heroSplit.videoVimeoId,
    }
  : undefined;

const mergedHelpGrid: HelpGridContent | undefined = payload?.content.helpGrid
  ? {
      heading: payload.content.helpGrid.heading,
      cards: payload.content.helpGrid.cards.map((c, i) => ({
        ...c,
        iconPaths:
          sampleContent.helpGrid.cards[i % sampleContent.helpGrid.cards.length]
            .iconPaths,
      })),
    }
  : undefined;

const mergedEffortless: EffortlessStrategyContent | undefined = payload
  ?.content.effortlessStrategy
  ? {
      ...payload.content.effortlessStrategy,
      image: { src: gradientUri, alt: '' },
      review: sampleContent.effortlessStrategy.review,
    }
  : undefined;

const mergedAbout: AboutBillContent | undefined = payload?.content.about
  ? {
      ...payload.content.about,
      photo: { src: gradientUri, alt: '' },
    }
  : undefined;

const mergedClosing: ClosingContent | undefined = payload?.content.closing
  ? {
      ...payload.content.closing,
      reviews: sampleContent.closing.reviews,
    }
  : undefined;

let cssVars = '';
if (payload) {
  try {
    const ds = payload.designSystem;
    cssVars = `
      :root {
        --wrks-palette-primary: ${ds.palette.primary.hex};
        --wrks-palette-secondary: ${ds.palette.secondary.hex};
        --wrks-palette-tertiary: ${ds.palette.tertiary.hex};
        --wrks-palette-neutral: ${ds.palette.neutral.hex};
        --wrks-display: "${ds.type.display.family}", ui-serif, Georgia, serif;
        --wrks-body: "${ds.type.body.family}", ui-sans-serif, system-ui, sans-serif;
      }
      body, .bf-body, .bf-lead, .bf-h1, .bf-h2, .bf-eyebrow {
        font-family: var(--wrks-body) !important;
      }
      .bf-h1, .bf-h2, .bf-hero2026__h1, .bf-hero-split__h1 {
        font-family: var(--wrks-display) !important;
      }
      /* Hide the tiny signature overlaid on About photos — it's Bill's
         and we replaced the photo with a gradient. */
      .bf-about__sig { display: none !important; }
    `;
  } catch (err) {
    parseError = `design-system parse: ${err instanceof Error ? err.message : String(err)}`;
  }
}
---
<BaseLayout
  title={payload?.content.title ?? 'WRKS Studio preview'}
  description="Generated site preview — WRKS Studio"
  wfPageId="preview"
>
  <ReactReady client:only="react" />
  {cssVars && <style set:html={cssVars} />}

  {parseError && (
    <div
      style="position:fixed;top:0;left:0;right:0;z-index:9999;background:#7a1616;color:#fff;padding:16px 24px;font-family:ui-monospace,monospace;font-size:13px"
    >
      Preview error: {parseError}. Falling back to canonical Bill-Fanter content.
    </div>
  )}

  <main class="bf-page" data-cardnav-host data-cardnav-variant="split">
    <Hero content={mergedHero} />
    {mergedHeroSplit && <HeroSplit content={mergedHeroSplit} />}
    <HelpGrid content={mergedHelpGrid} />
    {mergedEffortless && <EffortlessStrategy content={mergedEffortless} />}
    <AboutBill content={mergedAbout} />
    <Closing content={mergedClosing} />
  </main>
  <Footer />
  <Islands />
</BaseLayout>
